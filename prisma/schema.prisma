generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum GenerationJobStatus {
  RECEIVED
  REVIEWING
  READY_FOR_GENERATION
  PINS_GENERATED
  MEDIA_UPLOADED
  TITLES_GENERATED
  DESCRIPTIONS_GENERATED
  READY_TO_SCHEDULE
  SCHEDULED
  COMPLETED
  FAILED
}

enum GenerationPlanMode {
  ASSISTED_AUTO
  MANUAL
}

enum GenerationPlanStatus {
  DRAFT
  READY
  GENERATED
  FAILED
}

enum ArtworkReviewState {
  NORMAL
  FLAGGED
  RERENDER_QUEUED
  RERENDERING
  RERENDER_FAILED
}

enum BackgroundTaskStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum RuntimeHeartbeatKind {
  WEB
  WORKER
  SCHEDULER
}

enum OperationMetricStatus {
  SUCCEEDED
  FAILED
}

enum BackgroundTaskKind {
  RENDER_PLANS
  RERENDER_PLAN
  RECOMMEND_PLAN_PRESETS
  UPLOAD_MEDIA_BATCH
  GENERATE_TITLE_BATCH
  GENERATE_DESCRIPTION_BATCH
  SCHEDULE_PINS
  SYNC_PUBLICATIONS
  CLEAN_TEMP_ASSETS
}

enum WorkspaceOperationLockScope {
  MEDIA_UPLOAD
  SCHEDULING
  SYNC
}

enum PublerMetadataCacheKind {
  WORKSPACES
  ACCOUNTS
  BOARDS
}

enum PostPulseFreshnessStatus {
  FRESH
  NEEDS_FRESH_PINS
  SCHEDULED_IN_FLIGHT
  NEVER_PUBLISHED
  NO_PINS_YET
}

enum MediaUploadStatus {
  PENDING
  UPLOADING
  UPLOADED
  FAILED
}

enum PinCopyFieldStatus {
  EMPTY
  GENERATED
  FINALIZED
}

enum ScheduleRunStatus {
  DRAFT
  SUBMITTING
  SCHEDULED
  COMPLETED
  FAILED
}

enum ScheduleRunItemStatus {
  PENDING
  SUBMITTING
  SCHEDULED
  FAILED
}

enum PublicationRecordState {
  SCHEDULED
  PUBLISHED
  PUBLISHED_POSTED
  OTHER
}

enum PublicationSyncMode {
  BACKFILL
  INCREMENTAL
}

enum TemplateSourceKind {
  BUILTIN
  CUSTOM
}

enum TemplateLifecycleStatus {
  DRAFT
  FINALIZED
  ARCHIVED
}

enum TemplateRendererKind {
  BUILTIN_COMPONENT
  RUNTIME_SCHEMA
}

model User {
  id                  String   @id @default(cuid())
  authUserId          String?  @unique
  email               String   @unique
  createdAt           DateTime @default(now())
  apiKeys             ApiKey[]
  aiCredentials       AiCredential[]
  generationJobs      GenerationJob[]
  integrationSettings UserIntegrationSettings?
  publicationRecords  PublicationRecord[]
  publicationSyncStates PublicationSyncState[]
  workspaceProfiles   WorkspaceProfile[]
  freshTargetSnoozes  FreshTargetSnooze[]
  backgroundTasks     BackgroundTask[]
  publerMetadataCaches PublerMetadataCache[]
  postPulseSnapshots  PostPulseSnapshot[]
  createdTemplates    Template[]        @relation("UserCreatedTemplates")
  createdTemplateVersions TemplateVersion[] @relation("UserCreatedTemplateVersions")
}

model Post {
  id        String          @id @default(cuid())
  url       String          @unique
  title     String
  domain    String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  jobs      GenerationJob[]
  publicationRecords PublicationRecord[]
  freshTargetSnoozes FreshTargetSnooze[]
  postPulseSnapshots PostPulseSnapshot[]
}

model PostPulseSnapshot {
  id                 String                   @id @default(cuid())
  userId             String
  postId             String
  workspaceId        String                   @default("")
  latestJobId        String?
  totalJobs          Int                      @default(0)
  totalGeneratedPins Int                      @default(0)
  totalPublerRecords Int                      @default(0)
  publishedCount     Int                      @default(0)
  scheduledCount     Int                      @default(0)
  lastGeneratedAt    DateTime?
  lastPublishedAt    DateTime?
  lastScheduledAt    DateTime?
  lastSyncedAt       DateTime?
  freshnessStatus    PostPulseFreshnessStatus @default(NO_PINS_YET)
  freshnessAgeDays   Int?
  recentActivityDotsJson Json?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post               Post                     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, workspaceId])
  @@index([userId, workspaceId, freshnessStatus, updatedAt])
  @@index([userId, postId, workspaceId])
}

model FreshTargetSnooze {
  id          String   @id @default(cuid())
  userId      String
  postId      String
  workspaceId String   @default("")
  snoozedUntil DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, workspaceId])
  @@index([userId, workspaceId, snoozedUntil])
}

model GenerationJob {
  id                 String              @id @default(cuid())
  userId             String
  postId             String
  postUrlSnapshot    String
  articleTitleSnapshot String
  domainSnapshot     String
  status             GenerationJobStatus @default(RECEIVED)
  globalKeywords     String[] @default([])
  titleStyle         String?
  toneHint           String?
  listCountHint      Int?
  titleVariationCount Int?
  requestedPinCount  Int?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  post               Post                @relation(fields: [postId], references: [id], onDelete: Cascade)
  sourceImages       JobSourceImage[]
  generationPlans    GenerationPlan[]
  generatedPins      GeneratedPin[]
  milestones         JobMilestone[]
  scheduleRuns       ScheduleRun[]
  backgroundTasks    BackgroundTask[]

  @@index([userId, status, createdAt])
  @@index([postId, createdAt])
  @@index([userId, postId, status, createdAt])
  @@index([userId, postId, createdAt])
}

model JobSourceImage {
  id                     String   @id @default(cuid())
  jobId                   String
  url                    String
  alt                    String?
  caption                String?
  nearestHeading         String?
  sectionHeadingPath     String[] @default([])
  surroundingTextSnippet String?
  isSelected             Boolean  @default(true)
  isPreferred            Boolean  @default(false)
  sortOrder              Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  job                    GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  planAssignments        GenerationPlanImageAssignment[]

  @@index([jobId, sortOrder])
}

model GenerationPlan {
  id               String               @id @default(cuid())
  jobId            String
  mode             GenerationPlanMode
  templateId       String
  templateVersionId String?
  sortOrder        Int                  @default(0)
  status           GenerationPlanStatus @default(DRAFT)
  artworkReviewState ArtworkReviewState @default(NORMAL)
  artworkFlagReason String?
  rerenderRequestedAt DateTime?
  rerenderError    String?
  notes            String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  job              GenerationJob        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  template         Template             @relation(fields: [templateId], references: [id], onDelete: Restrict)
  templateVersion  TemplateVersion?     @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  imageAssignments GenerationPlanImageAssignment[]
  generatedPins    GeneratedPin[]
  backgroundTasks  BackgroundTask[]

  @@index([jobId, status, sortOrder])
  @@index([jobId, artworkReviewState, sortOrder])
  @@index([templateVersionId])
}

model GenerationPlanImageAssignment {
  id            String         @id @default(cuid())
  planId        String
  sourceImageId String
  slotIndex     Int
  createdAt     DateTime       @default(now())
  plan          GenerationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  sourceImage   JobSourceImage @relation(fields: [sourceImageId], references: [id], onDelete: Cascade)

  @@unique([planId, slotIndex])
  @@index([sourceImageId])
}

model GeneratedPin {
  id               String            @id @default(cuid())
  jobId             String
  planId            String
  templateId        String
  templateVersionId String?
  exportPath        String
  storageKey        String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  job               GenerationJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  plan              GenerationPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  template          Template         @relation(fields: [templateId], references: [id], onDelete: Restrict)
  templateVersion   TemplateVersion? @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  pinCopy           PinCopy?
  publerMedia       PublerMedia?
  scheduleRunItems  ScheduleRunItem[]
  publicationRecords PublicationRecord[]
  backgroundTasks   BackgroundTask[]

  @@index([jobId, createdAt])
  @@index([planId])
  @@index([templateVersionId])
}

model PublicationRecord {
  id               String                 @id @default(cuid())
  userId           String
  postId           String
  generatedPinId   String?
  providerPostId   String
  providerWorkspaceId String?
  providerPostLink String?
  providerAccountId String?
  providerBoardId  String?
  state            PublicationRecordState
  rawState         String
  postUrl          String
  scheduledAt      DateTime?
  publishedAt      DateTime?
  rawPayload       Json?
  syncedAt         DateTime               @default(now())
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  post             Post                   @relation(fields: [postId], references: [id], onDelete: Cascade)
  generatedPin     GeneratedPin?          @relation(fields: [generatedPinId], references: [id], onDelete: SetNull)

  @@unique([userId, providerPostId])
  @@index([postId, state, publishedAt])
  @@index([userId, syncedAt])
  @@index([userId, providerWorkspaceId, syncedAt])
  @@index([generatedPinId])
  @@index([userId, state, scheduledAt])
  @@index([userId, postId, providerWorkspaceId, publishedAt])
}

model PublicationSyncState {
  id                String              @id @default(cuid())
  userId            String
  workspaceId       String
  mode              PublicationSyncMode @default(BACKFILL)
  nextPage          Int                 @default(0)
  lastCompletedAt   DateTime?
  lastRunAt         DateTime?
  lastError         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId, mode, updatedAt])
}

model Template {
  id              String                 @id @default(cuid())
  name            String
  componentKey    String                 @unique
  configJson      Json
  isActive        Boolean                @default(true)
  sourceKind      TemplateSourceKind     @default(BUILTIN)
  rendererKind    TemplateRendererKind   @default(BUILTIN_COMPONENT)
  lifecycleStatus TemplateLifecycleStatus @default(FINALIZED)
  slug            String?                @unique
  description     String?
  createdByUserId String?
  activeVersionId String?                @unique
  thumbnailPath   String?
  previewImagePath String?
  canvasWidth     Int                    @default(1080)
  canvasHeight    Int                    @default(1920)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  createdByUser   User?                  @relation("UserCreatedTemplates", fields: [createdByUserId], references: [id], onDelete: SetNull)
  activeVersion   TemplateVersion?       @relation("ActiveTemplateVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)
  versions        TemplateVersion[]      @relation("TemplateVersions")
  generatedPins   GeneratedPin[]
  generationPlans GenerationPlan[]

  @@index([sourceKind, lifecycleStatus, updatedAt])
  @@index([createdByUserId, updatedAt])
}

model TemplateVersion {
  id               String                  @id @default(cuid())
  templateId       String
  versionNumber    Int
  lifecycleStatus  TemplateLifecycleStatus @default(DRAFT)
  schemaJson       Json
  editorStateJson  Json?
  summaryJson      Json?
  validationJson   Json?
  isActive         Boolean                 @default(false)
  isLocked         Boolean                 @default(false)
  createdByUserId  String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  template         Template                @relation("TemplateVersions", fields: [templateId], references: [id], onDelete: Cascade)
  activeForTemplate Template?              @relation("ActiveTemplateVersion")
  createdByUser    User?                   @relation("UserCreatedTemplateVersions", fields: [createdByUserId], references: [id], onDelete: SetNull)
  generationPlans  GenerationPlan[]
  generatedPins    GeneratedPin[]

  @@unique([templateId, versionNumber])
  @@index([templateId, lifecycleStatus, createdAt])
  @@index([createdByUserId, createdAt])
}

model PublerMedia {
  id            String            @id @default(cuid())
  generatedPinId String           @unique
  status        MediaUploadStatus @default(PENDING)
  uploadJobId   String?
  mediaId       String?
  sourceUrl     String?
  errorMessage  String?
  rawResponse   Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  generatedPin  GeneratedPin      @relation(fields: [generatedPinId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model PinCopy {
  id                String             @id @default(cuid())
  generatedPinId    String             @unique
  title             String?
  titleOptions      String[]           @default([])
  description       String?
  titleStatus       PinCopyFieldStatus @default(EMPTY)
  descriptionStatus PinCopyFieldStatus @default(EMPTY)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  generatedPin      GeneratedPin       @relation(fields: [generatedPinId], references: [id], onDelete: Cascade)
}

model ScheduleRun {
  id             String            @id @default(cuid())
  jobId          String
  status         ScheduleRunStatus @default(DRAFT)
  workspaceId    String?
  accountId      String?
  boardId        String?
  firstPublishAt DateTime?
  intervalMinutes Int?
  jitterMinutes  Int?
  errorMessage   String?
  rawResponse    Json?
  submittedAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  job            GenerationJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  items          ScheduleRunItem[]

  @@index([jobId, status, createdAt])
}

model ScheduleRunItem {
  id            String                @id @default(cuid())
  scheduleRunId String
  generatedPinId String
  publerJobId   String?
  publerPostId  String?
  scheduledFor  DateTime?
  status        ScheduleRunItemStatus @default(PENDING)
  errorMessage  String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  scheduleRun   ScheduleRun           @relation(fields: [scheduleRunId], references: [id], onDelete: Cascade)
  generatedPin  GeneratedPin          @relation(fields: [generatedPinId], references: [id], onDelete: Cascade)

  @@unique([scheduleRunId, generatedPinId])
  @@index([status, scheduledFor])
}

model BackgroundTask {
  id             String               @id @default(cuid())
  kind           BackgroundTaskKind
  status         BackgroundTaskStatus @default(QUEUED)
  userId         String?
  jobId          String?
  planId         String?
  generatedPinId String?
  workspaceId    String?
  priority       Int                  @default(0)
  dedupeKey      String?
  payloadJson    Json
  progressJson   Json?
  attempts       Int                  @default(0)
  maxAttempts    Int                  @default(5)
  runAfter       DateTime             @default(now())
  lockedAt       DateTime?
  lockedBy       String?
  startedAt      DateTime?
  finishedAt     DateTime?
  lastError      String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  user           User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  job            GenerationJob?       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  plan           GenerationPlan?      @relation(fields: [planId], references: [id], onDelete: Cascade)
  generatedPin   GeneratedPin?        @relation(fields: [generatedPinId], references: [id], onDelete: Cascade)

  @@index([status, runAfter, priority, createdAt])
  @@index([dedupeKey, status, createdAt])
  @@index([userId, status, createdAt])
  @@index([jobId, kind, status, createdAt])
  @@index([workspaceId, kind, status, createdAt])
}

model RuntimeHeartbeat {
  id           String               @id @default(cuid())
  kind         RuntimeHeartbeatKind
  instanceId   String
  displayName  String?
  metadataJson Json?
  lastSeenAt   DateTime             @default(now())
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([kind, instanceId])
  @@index([kind, lastSeenAt])
}

model OperationMetric {
  id             String                @id @default(cuid())
  operationName  String
  status         OperationMetricStatus
  correlationId  String?
  userId         String?
  jobId          String?
  planId         String?
  generatedPinId String?
  workspaceId    String?
  durationMs     Int?
  metadataJson   Json?
  occurredAt     DateTime              @default(now())
  createdAt      DateTime              @default(now())

  @@index([operationName, occurredAt])
  @@index([status, occurredAt])
  @@index([workspaceId, occurredAt])
  @@index([userId, occurredAt])
}

model WorkspaceOperationLock {
  id             String                      @id @default(cuid())
  scope          WorkspaceOperationLockScope
  workspaceId    String
  holderId       String?
  acquiredAt     DateTime?
  leaseExpiresAt DateTime?
  ownerContext   Json?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@unique([scope, workspaceId])
  @@index([leaseExpiresAt])
}

model PublerMetadataCache {
  id         String                 @id @default(cuid())
  userId     String
  workspaceId String                @default("")
  cacheKind  PublerMetadataCacheKind
  cacheKey   String
  label      String?
  rawJson    Json
  fetchedAt  DateTime               @default(now())
  expiresAt  DateTime
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, cacheKind, cacheKey])
  @@index([userId, cacheKind, expiresAt])
  @@index([workspaceId, cacheKind, expiresAt])
}

model JobMilestone {
  id        String              @id @default(cuid())
  jobId      String
  status    GenerationJobStatus
  details   String?
  createdAt DateTime            @default(now())
  job       GenerationJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, status])
  @@index([jobId, createdAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyPrefix  String    @unique
  keyHash    String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model UserIntegrationSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  publerApiKeyEnc   String?
  publerWorkspaceId String?
  publerAllowedDomains String[] @default([])
  publerAccountId   String?
  publerBoardId     String?
  aiProvider        String?
  aiApiKeyEnc       String?
  aiModel           String?
  aiCustomEndpoint  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkspaceProfile {
  id               String   @id @default(cuid())
  userId           String
  workspaceId      String
  workspaceName    String
  allowedDomains   String[] @default([])
  sitemapUrls      String[] @default([])
  dailyPublishTarget Int?
  defaultAccountId String?
  defaultBoardId   String?
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId, isDefault])
}

model AiCredential {
  id               String   @id @default(cuid())
  userId           String
  label            String
  provider         String
  apiKeyEnc        String?
  model            String?
  customEndpoint   String?
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isDefault])
}
