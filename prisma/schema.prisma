generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GenerationJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id                  String   @id @default(cuid())
  authUserId          String?  @unique
  email               String   @unique
  createdAt           DateTime @default(now())
  apiKeys             ApiKey[]
  integrationSettings UserIntegrationSettings?
}

model Post {
  id        String          @id @default(cuid())
  url       String          @unique
  title     String
  domain    String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  jobs      GenerationJob[]
}

model GenerationJob {
  id                 String              @id @default(cuid())
  postId             String
  status             GenerationJobStatus @default(PENDING)
  requestedTemplates String[]
  sourceImages       Json?
  generatedCopy      Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  post               Post                @relation(fields: [postId], references: [id], onDelete: Cascade)
  generatedPins      GeneratedPin[]
}

model GeneratedPin {
  id           String        @id @default(cuid())
  jobId        String
  templateId   String
  title        String
  description  String?
  exportPath   String
  publerPostId String?
  scheduledAt  DateTime?
  createdAt    DateTime      @default(now())
  job          GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  template     Template      @relation(fields: [templateId], references: [id], onDelete: Restrict)
}

model Template {
  id            String         @id
  name          String
  componentKey  String         @unique
  configJson    Json
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  generatedPins GeneratedPin[]
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyPrefix  String    @unique
  keyHash    String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model UserIntegrationSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  publerApiKeyEnc   String?
  publerWorkspaceId String?
  publerAccountId   String?
  publerBoardId     String?
  aiProvider        String?
  aiApiKeyEnc       String?
  aiModel           String?
  aiCustomEndpoint  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
