# Core app
APP_URL="https://your-domain.example.com"
APP_ENCRYPTION_KEY="replace-with-a-long-random-secret"
APP_ENCRYPTION_KEY_FALLBACKS=""

# Database
# Production currently uses the Supabase pooler hostname on :5432.
# The app runtime rewrites Supabase pooler traffic to :6543 transaction mode when needed.
DATABASE_URL="postgresql://<db-user>.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres?schema=public&sslmode=require"

# Optional: use this to tune Prisma pooler pressure on persistent deployments like Coolify.
PRISMA_CONNECTION_LIMIT="3"

# Optional: direct database connection for Prisma migrations / studio maintenance.
# DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"

# Supabase auth
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"

# Storage
# If these R2 variables are present, the app automatically uses R2 storage.
# STORAGE_PROVIDER="r2"
# LOCAL_STORAGE_PATH="./storage"
R2_ACCOUNT_ID=""
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET_NAME=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_BASE_URL="https://<public-bucket-or-domain>"
